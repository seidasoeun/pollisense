# Copy this file to .env.local and edit it for your OpenNebula VMs.
# At minimum, check VM2_IP before joining the worker.
# .env.local is machine-specific and should not be committed.

VM1_IP=172.16.100.2
VM2_IP=172.16.100.3
VM1_HOSTNAME=pollisense-vm1
VM2_HOSTNAME=pollisense-vm2
SSH_USER=root
DEBUG_PASS=debug
NAMESPACE=pollisense
FRONTEND_PORT=9999
BACKEND_PORT=8080
REPO_URL=https://github.com/seidasoeun/pollisense.git
APP_DIR=$HOME/pollisense
